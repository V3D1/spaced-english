{
  "name": "spaced-english",
  "version": "1.0.0",
  "description": "Self-hosted English learning platform with spaced repetition (SM-2). Master B2-C2 collocations through flashcards, drills, and daily practice.",
  "author": "Maciej Kick",
  "license": "MIT",
  "homepage": "https://github.com/V3D1/spaced-english",
  "repository": {
    "type": "git",
    "url": "https://github.com/V3D1/spaced-english.git"
  },
  "keywords": [
    "spaced-repetition",
    "sm2",
    "english-learning",
    "collocations",
    "flashcards",
    "nextjs",
    "self-hosted",
    "pwa"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "bash scripts/setup.sh",
    "db:seed": "npx tsx lib/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "progress:reset": "npx tsx scripts/reset_progress.ts",
    "security:report": "npx tsx scripts/security_report.ts",
    "security:unlock": "npx tsx scripts/security_unlock.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.1.7",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "jose": "^6.0.11",
    "lucide-react": "^0.511.0",
    "next": "16.1.6",
    "postcss": "^8.5.3",
    "postgres": "^3.4.5",
    "radix-ui": "^1.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "4.1.7",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "vitest": "^3.2.1"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
