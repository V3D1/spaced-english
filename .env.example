# Required — database connection
POSTGRES_URL=postgresql://spaced:spaced_dev@localhost:5432/spaced_english

# Required — session signing key (run: openssl rand -base64 32)
AUTH_SECRET=

# Required for db:seed — creates the initial user account
SEED_USER_EMAIL=you@example.com
SEED_USER_PASSWORD=change_me_min_12_chars

# Optional — defaults shown
SESSION_TTL_DAYS=90
LOGIN_RATE_WINDOW_MINUTES=15
LOGIN_RATE_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_LEVELS_MINUTES=15,60,1440
AUTH_LOG_RETENTION_DAYS=30
